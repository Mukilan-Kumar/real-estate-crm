            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Luxury Apartment\",\n  \"location\": \"Mumbai, Maharashtra\",\n  \"price\": 16000000,\n  \"propertyType\": \"APARTMENT\",\n  \"status\": \"AVAILABLE\",\n  \"description\": \"Updated description\",\n  \"bedrooms\": 3,\n  \"bathrooms\": 2,\n  \"area\": 1500.0,\n  \"imageUrl\": \"https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&q=80\"\n}",
